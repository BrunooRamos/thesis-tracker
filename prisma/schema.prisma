generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String          @default("")
  needsSetup      Boolean         @default(true)
  avatar          String?
  role            String          @default("member")
  assignedTasks   Task[]          @relation("assignees")
  createdTasks    Task[]          @relation("creator")
  researchEntries ResearchEntry[]
  experiments     Experiment[]
  comments        Comment[]
  decisions       Decision[]
  meetingNotes    MeetingNote[]
  resources       Resource[]
  notifications   Notification[]
  ownedActivities Activity[]      @relation("activityOwners")
  createdAt       DateTime        @default(now())
}

model Phase {
  id          String      @id @default(cuid())
  number      Int
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      PhaseStatus @default(NOT_STARTED)
  progress    Int         @default(0)
  tasks       Task[]
  milestones  Milestone[]
  activities  Activity[]
  createdAt   DateTime    @default(now())
}

model Milestone {
  id          String          @id @default(cuid())
  code        String
  name        String
  description String?
  dueDate     DateTime
  status      MilestoneStatus @default(PENDING)
  isFaculty   Boolean         @default(false)
  phase       Phase           @relation(fields: [phaseId], references: [id])
  phaseId     String
  createdAt   DateTime        @default(now())
}

model Task {
  id              String         @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus     @default(TODO)
  priority        Priority       @default(MEDIUM)
  assignees       User[]         @relation("assignees")
  creator         User           @relation("creator", fields: [creatorId], references: [id])
  creatorId       String
  phase           Phase?         @relation(fields: [phaseId], references: [id])
  phaseId         String?
  dueDate         DateTime?
  tags            Tag[]
  comments        Comment[]
  wbsCode         String?
  resource        Resource?      @relation("ResourceTask", fields: [resourceId], references: [id], onDelete: SetNull)
  resourceId      String?
  researchEntry   ResearchEntry? @relation("ResearchTask", fields: [researchEntryId], references: [id], onDelete: SetNull)
  researchEntryId String?
  decision        Decision?      @relation("DecisionTask", fields: [decisionId], references: [id], onDelete: SetNull)
  decisionId      String?
  activity        Activity?      @relation(fields: [activityId], references: [id], onDelete: SetNull)
  activityId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6B7280")
  tasks Task[]
}

model ResearchEntry {
  id          String       @id @default(cuid())
  title       String
  type        ResearchType
  url         String?
  authors     String?
  summary     String
  keyFindings String?
  relevance   Relevance    @default(MEDIUM)
  tags        String[]
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  comments    Comment[]
  experiments Experiment[] @relation("ExperimentResearch")
  resource    Resource?    @relation("ResourceResearch", fields: [resourceId], references: [id], onDelete: SetNull)
  resourceId  String?
  tasks       Task[]       @relation("ResearchTask")
  decisions   Decision[]   @relation("ResearchDecision")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Experiment {
  id               String           @id @default(cuid())
  name             String
  description      String?
  hypothesis       String?
  architecture     String
  configuration    Json?
  dataset          String?
  status           ExperimentStatus @default(PLANNED)
  exhaustivity     Float?
  precision        Float?
  latency          Float?
  cost             Float?
  tokenCount       Int?
  customMetrics    Json?
  results          String?
  analysis         String?
  nextSteps        String?
  iteration        Int              @default(1)
  parentExperiment Experiment?      @relation("iterations", fields: [parentId], references: [id])
  parentId         String?
  childExperiments Experiment[]     @relation("iterations")
  user             User             @relation(fields: [userId], references: [id])
  userId           String
  researchEntries  ResearchEntry[]  @relation("ExperimentResearch")
  decisions        Decision[]       @relation("ExperimentDecision")
  comments         Comment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Decision {
  id              String          @id @default(cuid())
  title           String
  context         String
  decision        String
  rationale       String
  alternatives    String?
  impact          String?
  status          DecisionStatus  @default(PROPOSED)
  madeBy          User            @relation(fields: [madeById], references: [id])
  madeById        String
  comments        Comment[]
  // Links to origin context
  meetingNote     MeetingNote?    @relation(fields: [meetingNoteId], references: [id], onDelete: SetNull)
  meetingNoteId   String?
  researchEntry   ResearchEntry?  @relation("ResearchDecision", fields: [researchEntryId], references: [id], onDelete: SetNull)
  researchEntryId String?
  experiment      Experiment?     @relation("ExperimentDecision", fields: [experimentId], references: [id], onDelete: SetNull)
  experimentId    String?
  // Tasks spawned from this decision
  tasks           Task[]          @relation("DecisionTask")
  history         Json[]
  createdAt       DateTime        @default(now())
}

model MeetingNote {
  id              String      @id @default(cuid())
  title           String
  date            DateTime
  type            MeetingType
  attendees       String[]
  summary         String
  actionItems     Json[]
  keyDecisions    String?
  // Multiple attachments: files + links
  // Each item: { type: "file"|"link", name: string, url: string, fileType?: string }
  attachments     Json[]
  author          User        @relation(fields: [authorId], references: [id])
  authorId        String
  decisions       Decision[]
  createdAt       DateTime    @default(now())
}

model Comment {
  id              String         @id @default(cuid())
  content         String
  user            User           @relation(fields: [userId], references: [id])
  userId          String
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId          String?
  researchEntry   ResearchEntry? @relation(fields: [researchEntryId], references: [id], onDelete: Cascade)
  researchEntryId String?
  experiment      Experiment?    @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  experimentId    String?
  decision        Decision?      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  decisionId      String?
  activity        Activity?      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId      String?
  createdAt       DateTime       @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // task_assigned, comment_added, milestone_approaching, decision_created, mentioned
  title       String
  message     String
  read        Boolean  @default(false)
  entityType  String?  // task, research, experiment, decision, meeting
  entityId    String?
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}

model Resource {
  id              String           @id @default(cuid())
  name            String
  url             String?
  fileUrl         String?
  fileName        String?
  fileType        String?
  description     String?
  category        ResourceCategory
  pinned          Boolean          @default(false)
  addedBy         User             @relation(fields: [addedById], references: [id])
  addedById       String
  researchEntries ResearchEntry[]  @relation("ResourceResearch")
  tasks           Task[]           @relation("ResourceTask")
  createdAt       DateTime         @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  entityTitle String
  userId      String
  userName    String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Activity {
  id                 String                @id @default(cuid())
  wbsCode            String                @unique
  name               String
  description        String?
  status             ActivityStatus        @default(NOT_STARTED)
  startDate          DateTime?
  endDate            DateTime?
  phase              Phase                 @relation(fields: [phaseId], references: [id])
  phaseId            String
  owners             User[]                @relation("activityOwners")
  tasks              Task[]
  deliverables       Deliverable[]
  acceptanceCriteria AcceptanceCriterion[]
  comments           Comment[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model Deliverable {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String?
  fileName    String?
  fileType    String?
  order       Int      @default(0)
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId  String
  createdAt   DateTime @default(now())
}

model AcceptanceCriterion {
  id         String   @id @default(cuid())
  text       String
  done       Boolean  @default(false)
  order      Int      @default(0)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String
  createdAt  DateTime @default(now())
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  AT_RISK
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResearchType {
  PAPER
  ARTICLE
  REPO
  TOOL
  VIDEO
  OTHER
}

enum Relevance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  COMPLETED
  FAILED
}

enum DecisionStatus {
  PROPOSED
  ACCEPTED
  REVISITED
}

enum MeetingType {
  HORIZON_CHECKIN
  TEAM_INTERNAL
  TUTOR_ACADEMIC
  OTHER
}

enum ResourceCategory {
  PAPER
  TOOL
  DATASET
  HORIZON_DOC
  REPO
  FACULTY_DOC
  OTHER
}
