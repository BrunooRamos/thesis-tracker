generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String          @default("")
  needsSetup      Boolean         @default(true)
  avatar          String?
  role            String          @default("member")
  assignedTasks   Task[]          @relation("assignee")
  createdTasks    Task[]          @relation("creator")
  researchEntries ResearchEntry[]
  experiments     Experiment[]
  comments        Comment[]
  decisions       Decision[]
  meetingNotes    MeetingNote[]
  createdAt       DateTime        @default(now())
}

model Phase {
  id          String      @id @default(cuid())
  number      Int
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      PhaseStatus @default(NOT_STARTED)
  progress    Int         @default(0)
  tasks       Task[]
  milestones  Milestone[]
  createdAt   DateTime    @default(now())
}

model Milestone {
  id          String          @id @default(cuid())
  code        String
  name        String
  description String?
  dueDate     DateTime
  status      MilestoneStatus @default(PENDING)
  isFaculty   Boolean         @default(false)
  phase       Phase           @relation(fields: [phaseId], references: [id])
  phaseId     String
  createdAt   DateTime        @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  assignee    User?      @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  creator     User       @relation("creator", fields: [creatorId], references: [id])
  creatorId   String
  phase       Phase?     @relation(fields: [phaseId], references: [id])
  phaseId     String?
  dueDate     DateTime?
  tags        Tag[]
  comments    Comment[]
  wbsCode     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6B7280")
  tasks Task[]
}

model ResearchEntry {
  id          String       @id @default(cuid())
  title       String
  type        ResearchType
  url         String?
  authors     String?
  summary     String
  keyFindings String?
  relevance   Relevance    @default(MEDIUM)
  tags        String[]
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  comments    Comment[]
  experiments Experiment[] @relation("ExperimentResearch")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Experiment {
  id               String           @id @default(cuid())
  name             String
  description      String?
  hypothesis       String?
  architecture     String
  configuration    Json?
  dataset          String?
  status           ExperimentStatus @default(PLANNED)
  exhaustivity     Float?
  precision        Float?
  latency          Float?
  cost             Float?
  tokenCount       Int?
  customMetrics    Json?
  results          String?
  analysis         String?
  nextSteps        String?
  iteration        Int              @default(1)
  parentExperiment Experiment?      @relation("iterations", fields: [parentId], references: [id])
  parentId         String?
  childExperiments Experiment[]     @relation("iterations")
  user             User             @relation(fields: [userId], references: [id])
  userId           String
  researchEntries  ResearchEntry[]  @relation("ExperimentResearch")
  comments         Comment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Decision {
  id           String         @id @default(cuid())
  title        String
  context      String
  decision     String
  rationale    String
  alternatives String?
  impact       String?
  status       DecisionStatus @default(PROPOSED)
  madeBy       User           @relation(fields: [madeById], references: [id])
  madeById     String
  comments     Comment[]
  createdAt    DateTime       @default(now())
}

model MeetingNote {
  id           String      @id @default(cuid())
  title        String
  date         DateTime
  type         MeetingType
  attendees    String[]
  summary      String
  actionItems  Json[]
  keyDecisions String?
  author       User        @relation(fields: [authorId], references: [id])
  authorId     String
  createdAt    DateTime    @default(now())
}

model Comment {
  id              String         @id @default(cuid())
  content         String
  user            User           @relation(fields: [userId], references: [id])
  userId          String
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId          String?
  researchEntry   ResearchEntry? @relation(fields: [researchEntryId], references: [id], onDelete: Cascade)
  researchEntryId String?
  experiment      Experiment?    @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  experimentId    String?
  decision        Decision?      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  decisionId      String?
  createdAt       DateTime       @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  entityTitle String
  userId      String
  userName    String
  metadata    Json?
  createdAt   DateTime @default(now())
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  AT_RISK
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResearchType {
  PAPER
  ARTICLE
  REPO
  TOOL
  VIDEO
  OTHER
}

enum Relevance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  COMPLETED
  FAILED
}

enum DecisionStatus {
  PROPOSED
  ACCEPTED
  REVISITED
}

enum MeetingType {
  HORIZON_CHECKIN
  TEAM_INTERNAL
  TUTOR_ACADEMIC
  OTHER
}
